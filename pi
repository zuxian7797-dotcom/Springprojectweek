GPIO.setmode(GPIO.BCM)
GPIO.setwarnings(False)

ENA, IN1, IN2 = 18, 17, 27 
ENB, IN3, IN4 = 24, 22, 23
SERVO_PIN = 21  

GPIO.setup([IN1, IN2, IN3, IN4, ENA, ENB], GPIO.OUT)
pwm_a = GPIO.PWM(ENA, 100)
pwm_b = GPIO.PWM(ENB, 100)
