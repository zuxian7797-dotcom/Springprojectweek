        roi = thresh[80:320, :]
        contours, _ = cv2.findContours(roi, cv2.RETR_TREE, cv2.CHAIN_APPROX_SIMPLE)

        if contours:
            c = max(contours, key=cv2.contourArea)#c is contour coordinate
            M = cv2.moments(c)
            x, y, w, h = cv2.boundingRect(c) 
            
            if M["m00"] != 0:
                cx = int(M["m10"] / M["m00"])#How many pixel you have / total of the pixel of x coordinate
                current_cx = cx
                line_detected = True

                if pending_turn and w > 80 and not is_maneuvering:
                    log_msg(f"\n[*] T-Junction Detected (Width: {w})! Firing {pending_turn}...")
                    threading.Thread(target=execute_maneuver, args=(pending_turn,), daemon=True).start()
                    pending_turn = None
                    continue 

                if not is_maneuvering and robot_state == "running":
                    error = cx - 160
                    if error > 40: historical_turn_direction = "right"
                    elif error < -40: historical_turn_direction = "left"
                    elif abs(error) < 15: historical_turn_direction = "straight"
                        
