pwm_b.start(0)

# --- GLOBALS FOR SMART TURNING ---
is_maneuvering = False
robot_state = "running"
pending_turn = None      
line_detected = False     
current_cx = 160         

BASE_SPEED, TURN_SPEED = 22, 50

# --- NEW: Log Storage System ---
pi_logs = []

def log_msg(message):
    print(message) # Still print on the Pi's terminal
    pi_logs.append(message) # Save for the Mac to fetch

def set_motor_speed(left, right):
    if left >= 0:
        GPIO.output(IN1, GPIO.LOW); GPIO.output(IN2, GPIO.HIGH)
    else:
        GPIO.output(IN1, GPIO.HIGH); GPIO.output(IN2, GPIO.LOW)
    pwm_a.ChangeDutyCycle(min(abs(left), 100))
    if right >= 0:
        GPIO.output(IN3, GPIO.LOW); GPIO.output(IN4, GPIO.HIGH)
    else:
        GPIO.output(IN3, GPIO.HIGH); GPIO.output(IN4, GPIO.LOW)
    pwm_b.ChangeDutyCycle(min(abs(right), 100))

# ==========================================
# 2. Maneuver Logic (VISION ASSISTED)
# ==========================================
def execute_maneuver(action):
    global is_maneuvering, robot_state
    is_maneuvering = True
    log_msg(f"\n[!!!] PI EXECUTING: {action} [!!!]")
    
    if action == "stop_for_auth":
        set_motor_speed(0, 0)
        robot_state = "stop_for_auth"
        return 

    elif action == "stop_2s" or action == "stop":
        set_motor_speed(0, 0)
        time.sleep(2.0)
    elif action == "spin_360":
        set_motor_speed(-90, 90) 
        time.sleep(1.5) 
        set_motor_speed(0, 0)
        
    elif action == "turn_left":
        set_motor_speed(BASE_SPEED, BASE_SPEED)
        time.sleep(0.3)
        set_motor_speed(-TURN_SPEED, TURN_SPEED)
        time.sleep(0.4)
        while True:
            set_motor_speed(-TURN_SPEED, TURN_SPEED)
            if line_detected and 100 < current_cx < 220:
                set_motor_speed(0, 0) 
                time.sleep(0.15)
                break 
            time.sleep(0.02)
            
    elif action == "turn_right":
        set_motor_speed(BASE_SPEED, BASE_SPEED)
        time.sleep(0.5)
        set_motor_speed(TURN_SPEED, -TURN_SPEED)
        time.sleep(0.5)
        while True:
            set_motor_speed(TURN_SPEED, -TURN_SPEED)
            if line_detected and 100 < current_cx < 220:
                set_motor_speed(0, 0)
                time.sleep(0.15)
                break
            time.sleep(0.02)
    
    is_maneuvering = False
    robot_state = "running"

