@app.route('/video_feed')#Streams the processed camera frames to your Mac using a "Multipart" response.
def video_feed():
    def generate():
        while True:
            with lock:
                if latest_jpeg:
                    # NEW: Calculate exact size of the image to prevent Mac OpenCV errors
                    length = len(latest_jpeg)
                    header = f"--frame\r\nContent-Type: image/jpeg\r\nContent-Length: {length}\r\n\r\n".encode()
                    
                    yield (header + latest_jpeg + b'\r\n')
            time.sleep(0.04)
    return Response(generate(), mimetype='multipart/x-mixed-replace; boundary=frame')

@app.route('/command/<action>')#Receives instructions like stop, spin_360, or turn_left from the Mac.
def handle_command(action):
    global robot_state, pending_turn, is_maneuvering
    
    if action == "running": 
        robot_state = "running"
        is_maneuvering = False
        
    elif action in ["turn_left", "turn_right"]:
        pending_turn = action
        log_msg(f"[*] Mac sent {action} -> Waiting for T-Junction...")
        
    elif not is_maneuvering:
        threading.Thread(target=execute_maneuver, args=(action,), daemon=True).start()
        
    return f"Ok: {action}"

# --- NEW: Route to fetch logs ---
@app.route('/logs')#Allows the Mac to "drain" the pi_logs list so you can debug the Pi's status remotely.
def get_logs():
    global pi_logs
    with lock:
        logs_to_send = list(pi_logs)
        pi_logs.clear() 
    return Response(json.dumps({"logs": logs_to_send}), mimetype='application/json')

