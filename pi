            if not is_maneuvering and robot_state == "running":
                FAST_RECOVERY_SPEED = 50  
                if historical_turn_direction == "right": set_motor_speed(FAST_RECOVERY_SPEED, -FAST_RECOVERY_SPEED)
                elif historical_turn_direction == "left": set_motor_speed(-FAST_RECOVERY_SPEED, FAST_RECOVERY_SPEED)
                else: set_motor_speed(BASE_SPEED - 5, BASE_SPEED - 5)

